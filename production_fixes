  const encryptSensitiveData = (data: string): string => {
    const cipher = crypto.createCipher('aes-256-cbc',
  process.env.ENCRYPTION_KEY);
    let encrypted = cipher.update(data, 'utf8', 'hex');
    encrypted += cipher.final('hex');
    return encrypted;
  };

